{
  "name": "Karryt-platform",
  "version": "1.0.0",
  "description": "Karryt - Plataforma de conexión para conductores de camionetas y camiones de carga",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "build:web": "cd flutter_app && flutter pub get && flutter build web",
    "start:karryt": "powershell -ExecutionPolicy Bypass -File ./start-karryt.ps1",
    "start:flutter": "npm run build:web && npm start",
    "start": "node server.js",
    "deploy": "npm run build:web && firebase deploy"
  },
  "keywords": [
    "carga",
    "logística",
    "camiones",
    "camionetas",
    "transporte"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5",
    "firebase-admin": "^12.0.0",
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": "18"
  }
}

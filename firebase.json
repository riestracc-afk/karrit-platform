{
  "hosting": {
    "public": "flutter_app/build/hosting",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/chofer{,/**}",
        "destination": "/chofer/index.html"
      },
      {
        "source": "/admin{,/**}",
        "destination": "/admin/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

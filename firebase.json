{
  "hosting": {
    "site": "project-404e35e2-6a5d-421b-970",
    "public": "flutter_app/build/hosting",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api{,/**}",
        "run": {
          "serviceId": "karryt-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/socket.io{,/**}",
        "run": {
          "serviceId": "karryt-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/chofer{,/**}",
        "destination": "/chofer/index.html"
      },
      {
        "source": "/admin{,/**}",
        "destination": "/admin/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
